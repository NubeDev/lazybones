{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lazybones",
  "version": "0.1.0",
  "identifier": "io.nube.lazybones",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:51840",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "lazybones",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' http://127.0.0.1:46787 http://localhost:46787 ws://127.0.0.1:46787"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
